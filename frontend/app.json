{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0D0D",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "android": {
      "package": "com.yebichu.barbershop",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "statusBar": {
        "backgroundColor": "#0D0D0D00",
        "translucent": true,
        "barStyle": "light-content"
      },
      "navigationBar": {
        "backgroundColor": "#0D0D0D",
        "barStyle": "light-content"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "barbershop"
          },
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you upload showcase images for services and styles."
        }
      ]
    ]
  }
}